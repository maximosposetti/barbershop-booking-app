generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum ImageCategory {
  SHOP
  HAIRCUT
  BARBER
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  phone               String?
  passwordHash        String?
  role                Role                 @default(USER)
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  reservations        Reservation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Barber {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String
  imageUrl          String
  active            Boolean            @default(true)
  availabilityRules AvailabilityRule[]
  unavailableBlocks UnavailableBlock[]
  reservations      Reservation[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model AvailabilityRule {
  id          String @id @default(cuid())
  barberId    String
  weekday     Int
  startTime   String
  endTime     String
  slotMinutes Int    @default(30)
  barber      Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
}

model UnavailableBlock {
  id        String   @id @default(cuid())
  barberId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Reservation {
  id             String            @id @default(cuid())
  userId         String
  barberId       String
  startAt        DateTime
  endAt          DateTime
  status         ReservationStatus @default(PENDING_PAYMENT)
  priceCents     Int               @default(500000)
  notes          String?
  createdByAdmin Boolean           @default(false)
  user           User              @relation(fields: [userId], references: [id])
  barber         Barber            @relation(fields: [barberId], references: [id])
  payment        Payment?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([barberId, startAt])
  @@index([userId, startAt])
}

model Payment {
  id            String        @id @default(cuid())
  reservationId String        @unique
  provider      String        @default("MERCADO_PAGO")
  preferenceId  String?
  externalId    String?
  status        PaymentStatus @default(PENDING)
  amountCents   Int
  rawPayload    Json?
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model GalleryImage {
  id        String        @id @default(cuid())
  title     String
  url       String
  category  ImageCategory
  createdAt DateTime      @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}
